    {
      "parameters": {
        "jsCode": "// Calculate recovery stage based on time elapsed\nconst lastActivity = new Date($input.item.json.last_activity);\nconst now = new Date();\nconst hoursElapsed = (now - lastActivity) / (1000 * 60 * 60);\nconst currentStage = $input.item.json.recovery_stage || 0;\n\nlet nextStage = currentStage;\nlet shouldSend = false;\n\nif (hoursElapsed >= 0.5 && currentStage === 0) {\n  nextStage = 1;\n  shouldSend = true;\n} else if (hoursElapsed >= 6 && currentStage === 1) {\n  nextStage = 2;\n  shouldSend = true;\n} else if (hoursElapsed >= 24 && currentStage === 2) {\n  nextStage = 3;\n  shouldSend = true;\n}\n\nreturn {\n  json: {\n    ...$input.item.json,\n    hours_elapsed: hoursElapsed,\n    next_stage: nextStage,\n    should_send: shouldSend\n  }\n};"
      },
