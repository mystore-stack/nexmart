        "operation": "executeQuery",
        "query": "INSERT INTO \"AbandonedCartRecovery\" (\n  \"userId\",\n  \"cartValue\",\n  \"itemsCount\",\n  \"recoveryEmail1\",\n  \"recoveryEmail2\",\n  \"recoveryEmail3\",\n  \"couponGenerated\",\n  \"couponCode\",\n  \"lastActivityAt\"\n) VALUES (\n  '{{ $json.user_id }}',\n  {{ $json.cart_value }},\n  {{ $json.items_count }},\n  {{ $json.next_stage >= 1 }},\n  {{ $json.next_stage >= 2 }},\n  {{ $json.next_stage >= 3 }},\n  {{ $json.next_stage >= 3 }},\n  '{{ $json.coupon_code || \"\" }}',\n  NOW()\n) ON CONFLICT (\"userId\") DO UPDATE SET\n  \"recoveryEmail1\" = EXCLUDED.\"recoveryEmail1\" OR \"AbandonedCartRecovery\".\"recoveryEmail1\",\n  \"recoveryEmail2\" = EXCLUDED.\"recoveryEmail2\" OR \"AbandonedCartRecovery\".\"recoveryEmail2\",\n  \"recoveryEmail3\" = EXCLUDED.\"recoveryEmail3\" OR \"AbandonedCartRecovery\".\"recoveryEmail3\",\n  \"couponGenerated\" = EXCLUDED.\"couponGenerated\" OR \"AbandonedCartRecovery\".\"couponGenerated\",\n  \"couponCode\" = COALESCE(EXCLUDED.\"couponCode\", \"AbandonedCartRecovery\".\"couponCode\"),\n  \"lastActivityAt\" = NOW();",
        "options": {}
      },
