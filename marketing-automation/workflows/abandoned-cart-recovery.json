        "query": "INSERT INTO \"MarketingCoupon\" (\n  \"organizationId\",\n  code,\n  type,\n  value,\n  \"minOrder\",\n  \"startDate\",\n  \"endDate\",\n  active,\n  \"userId\",\n  metadata\n) VALUES (\n  (SELECT id FROM \"Organization\" LIMIT 1),\n  'SAVE5NOW-' || SUBSTR(MD5(RANDOM()::TEXT), 1, 8),\n  'percentage',\n  5.0,\n  100.0,\n  NOW(),\n  NOW() + INTERVAL '7 days',\n  true,\n  '{{ $json.user_id }}',\n  '{\"generated_for\": \"abandoned_cart\", \"stage\": 3}'::jsonb\n) RETURNING code;",
