      "id": "schedule-trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [250, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  u.id as user_id,\n  u.email,\n  u.name,\n  u.locale,\n  COUNT(ci.id) as items_count,\n  SUM(p.price * ci.quantity) as cart_value,\n  MAX(ci.updatedAt) as last_activity,\n  COALESCE(acr.recovery_stage, 0) as recovery_stage\nFROM \"User\" u\nINNER JOIN \"CartItem\" ci ON u.id = ci.\"userId\"\nINNER JOIN \"Product\" p ON ci.\"productId\" = p.id\nLEFT JOIN \"AbandonedCartRecovery\" acr ON u.id = acr.\"userId\"\nWHERE \n  ci.updatedAt > NOW() - INTERVAL '48 hours'\n  AND NOT EXISTS (\n    SELECT 1 FROM \"Order\" o \n    WHERE o.\"userId\" = u.id \n    AND o.createdAt > ci.updatedAt\n  )\nGROUP BY u.id, u.email, u.name, u.locale, acr.recovery_stage\nHAVING COUNT(ci.id) > 0\nORDER BY last_activity DESC;",
        "options": {}
      },
      "id": "postgres-query-abandoned-carts",
