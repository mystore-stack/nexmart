    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  p.id,\n  p.name,\n  p.description,\n  p.price,\n  p.rating,\n  p.reviewCount,\n  p.soldCount,\n  c.name as category_name\nFROM \"Product\" p\nINNER JOIN \"Category\" c ON p.\"categoryId\" = c.id\nWHERE p.published = true\n  AND p.stock > 0\nORDER BY p.rating DESC, p.soldCount DESC\nLIMIT 10;",
        "options": {}
      },
