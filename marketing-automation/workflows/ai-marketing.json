    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO \"MarketingCampaign\" (\n  \"organizationId\",\n  name,\n  type,\n  status,\n  startDate,\n  metadata\n) VALUES (\n  (SELECT id FROM \"Organization\" LIMIT 1),\n  'AI Generated Campaign - ' || CURRENT_DATE,\n  'PROMOTION',\n  'DRAFT',\n  CURRENT_DATE,\n  '{\"generated_by\": \"ai\", \"products\": \"{{ $json.products }}\", \"subjects\": \"{{ $json.subjects }}\"}'::jsonb\n) RETURNING id;",
        "options": {}
      },
