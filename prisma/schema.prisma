  totalPublished  Int      @default(0)
  averageQuality  Float?
  averageSeoScore Float?
  generationTime  Int?
  aiUsage         Json?
  costPerProduct  Float?
  topCategories   Json?
  modelUsage      Json?
  languageUsage   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

