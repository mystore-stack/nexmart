// Enums
enum GoogleService {
  ANALYTICS
  TAG_MANAGER
  SEARCH_CONSOLE
  MERCHANT_CENTER
  BUSINESS_PROFILE
  RECAPTCHA
  MAPS
  OAUTH
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  PENDING
  SYNCING
}

enum FeedStatus {
  ACTIVE
  PENDING
  PROCESSING
  ERROR
  DISABLED
}

enum LocationType {
  STORE
  WAREHOUSE
  DELIVERY_ZONE
  PICKUP_POINT
}

// Homepage Section Models

model FeaturedCategory {
  id              String   @id @default(uuid()) @db.Uuid
  categoryId      String   @db.Uuid
  order           Int      @default(0)
  enabled         Boolean  @default(true)
  backgroundColor String?  @default("#ffffff")
  gradient        String?
  buttonText      String   @default("Shop Now")
  buttonUrl       String?
  description     String?
  image           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([enabled])
}

model SuperDeal {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  productId       String   @db.Uuid
  order           Int      @default(0)
  enabled         Boolean  @default(true)
  
  // Deal Configuration
  discountType    SuperDealDiscountType @default(PERCENTAGE)
  discountValue   Float
  originalPrice   Float?
  dealPrice       Float?
  
  // Scheduling
  startDate       DateTime?
  endDate         DateTime?
  autoStart       Boolean  @default(false)
  autoEnd         Boolean  @default(true)
  
  // Display Settings
  countdown       Boolean  @default(false)
  featured        Boolean  @default(false)
  flashSale       Boolean  @default(false)
  stockLimit      Int?
  
  // Visual Design
  image           String?
  bannerImage     String?
  backgroundColor String?  @default("#ffffff")
  gradient        String?
  
  // CTA Buttons
  buttonText      String   @default("Buy Now")
  buttonUrl       String?
  
  // SEO & Metadata
  title           String?
  description     String?
  seoTitle        String?
  seoDescription  String?
  ogImage         String?
  
  // Multi-language
  titleAr         String?
  titleFr         String?
  descriptionAr   String?
  descriptionFr   String?
  buttonTextAr    String?
  buttonTextFr    String?
  
  // AI Generation
  aiGenerated     Boolean  @default(false)
  aiPrompt        String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product         Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  analytics       SuperDealAnalytics[]

  @@index([organizationId])
  @@index([productId])
  @@index([enabled])
  @@index([startDate])
  @@index([endDate])
  @@index([featured])
  @@index([order])
}

model SuperDealAnalytics {
  id              String   @id @default(uuid()) @db.Uuid
  superDealId     String   @db.Uuid
  eventType       SuperDealEventType
  sessionId       String?
  userId          String?  @db.Uuid
  ipAddress       String?
  userAgent       String?
  metadata        Json?
  createdAt       DateTime @default(now())
  
  superDeal       SuperDeal @relation(fields: [superDealId], references: [id], onDelete: Cascade)

  @@index([superDealId])
  @@index([eventType])
  @@index([createdAt])
  @@index([userId])
}

enum SuperDealDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  BUY_ONE_GET_ONE
}

enum SuperDealEventType {
  IMPRESSION
  CLICK
  ADD_TO_CART
  PURCHASE
  VIEW_DETAILS
}

model BundleDeal {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  bundlePrice     Float
  discountPercent Float
  enabled         Boolean  @default(true)
  backgroundColor String?  @default("#ffffff")
  gradient        String?
  buttonText      String   @default("Buy Bundle")
  buttonUrl       String?
  image           String?
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  products        BundleProduct[]

  @@index([enabled])
}

model BundleProduct {
  id          String    @id @default(uuid()) @db.Uuid
  bundleId    String    @db.Uuid
  productId   String    @db.Uuid
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  bundle      BundleDeal @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([bundleId])
  @@index([productId])
}
