model AIProductImage {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  generationId    String?  @db.Uuid
  productId       String?  @db.Uuid
  
  // Image Type & View
  imageType       ProductImageType @default(MAIN)
  viewType        ProductImageView?
  
  // Cloudinary Data
  cloudinaryPublicId String?
  cloudinaryUrl    String?
  cloudinarySecureUrl String?
  format          String?  // "webp", "jpeg", "png"
  resourceType    String?  // "image"
  version         Int?
  signature       String?
  
  // Image Variants
  thumbnailUrl    String?
  smallUrl        String?
  mediumUrl       String?
  largeUrl        String?
  
  // Original & Processed URLs
  originalUrl     String?
  processedUrl    String?
  
  // Image Dimensions
  width           Int?
  height          Int?
  aspectRatio     Float?
  
  // File Information
  fileSize        Int?
  fileSizeBytes   Int?
  
  // SEO Data
  altText         String?
  title           String?
  caption         String?
  seoFilename     String?
  imageTitle      String?
  
  // Generation Data
  generationPrompt String?
  generationModel String?  // "dall-e-3", "dall-e-2"
  generationStatus ImageGenerationStatus @default(PENDING)
  qualityScore    Int?     // 0-100
  isApproved      Boolean  @default(false)
  isMain          Boolean  @default(false)
  sortOrder       Int      @default(0)
  
  // Processing Flags
  backgroundRemoved Boolean @default(false)
  enhanced        Boolean @default(false)
  compressed       Boolean @default(false)
  upscaled        Boolean @default(false)
  
  // Analysis Data
  tags            String[]
  dominantColors  String[]
  analysis        Json?
  metadata        Json?
  
  // Error Handling
  error           String?
  retryCount      Int      @default(0)
  maxRetries      Int      @default(3)
  
  // Timestamps
  generatedAt     DateTime?
  uploadedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  Organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generation      AiProductGeneration? @relation(fields: [generationId], references: [id], onDelete: SetNull)
  Product         Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([generationId])
  @@index([productId])
  @@index([imageType])
  @@index([generationStatus])
  @@index([isMain])
  @@index([sortOrder])
}

