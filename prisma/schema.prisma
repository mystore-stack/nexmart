generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String           @id @default(uuid()) @db.Uuid
  email          String           @unique
  name           String
  password       String
  avatar         String?
  phone          String?
  role           Role             @default(USER)
  emailVerified  Boolean          @default(false)
  verifyToken    String?
  resetToken     String?
  resetExpires   DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  locale         LocaleCode       @default(fr)
  addresses      Address[]
  AiConversation AiConversation[]
  AiEvent        AiEvent[]
  AuditLog       AuditLog[]
  cart           CartItem[]
  Membership     Membership[]
  notifications  Notification[]
  notificationLogs NotificationLog[]   @relation("UserNotificationLogs")
  orders         Order[]
  Organization   Organization[]
  viewedProducts RecentlyViewed[]
  reviews        Review[]
  Session        Session[]
  wishlist       WishlistItem[]

  @@index([email])
}

model Address {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  name      String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  country   String
  zip       String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([userId])
}

model Category {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  name           String
  slug           String
  description    String?
  image          String?
  parentId       String?      @db.Uuid
  createdAt      DateTime     @default(now())
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent         Category?    @relation("SubCategories", fields: [parentId], references: [id])
  children       Category[]   @relation("SubCategories")
  products       Product[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Product {
  id                 String                  @id @default(uuid()) @db.Uuid
  organizationId     String                  @db.Uuid
  name               String
  slug               String
  description        String
  price              Float
  comparePrice       Float?
  cost               Float?
  categoryId         String                  @db.Uuid
  images             String[]
  tags               String[]
  sku                String
  stock              Int                     @default(0)
  lowStockAt         Int                     @default(5)
  weight             Float?
  published          Boolean                 @default(false)
  featured           Boolean                 @default(false)
  rating             Float                   @default(0)
  reviewCount        Int                     @default(0)
  soldCount          Int                     @default(0)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  AiEvent            AiEvent[]
  AiProductEmbedding AiProductEmbedding?
  cartItems          CartItem[]
  orderItems         OrderItem[]
  category           Category                @relation(fields: [categoryId], references: [id])
  Organization       Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  variants           ProductVariant[]
  recentlyViewed     RecentlyViewed[]
  reviews            Review[]
  wishlistItems      WishlistItem[]
  reservations       InventoryReservation[]

  @@unique([organizationId, sku])
  @@unique([organizationId, slug])
  @@index([categoryId])
  @@index([published])
  @@index([featured])
  @@index([organizationId])
}

model ProductVariant {
  id         String                  @id @default(uuid()) @db.Uuid
  productId  String                  @db.Uuid
  name       String
  value      String
  label      String
  price      Float?
  stock      Int                     @default(0)
  sku        String?
  cartItems  CartItem[]
  orderItems OrderItem[]
  product    Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  reservations InventoryReservation[]

  @@index([productId])
}

model Review {
  id               String   @id @default(uuid()) @db.Uuid
  productId        String   @db.Uuid
  userId           String   @db.Uuid
  orderId          String?  @db.Uuid
  rating           Int
  title            String?
  body             String
  images           String[]
  helpfulCount     Int      @default(0)
  verifiedPurchase Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  order            Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
  @@index([orderId])
}

model CartItem {
  id        String          @id @default(uuid()) @db.Uuid
  userId    String          @db.Uuid
  productId String          @db.Uuid
  variantId String?         @db.Uuid
  quantity  Int             @default(1)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([userId, productId, variantId])
  @@index([userId])
}

model Order {
  id              String        @id @default(uuid()) @db.Uuid
  organizationId  String        @db.Uuid
  orderNumber     String
  userId          String        @db.Uuid
  customerId      String?       @db.Uuid
  addressId       String        @db.Uuid
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  paymentMethod   PaymentMethod
  subtotal        Float
  discount        Float         @default(0)
  shipping        Float         @default(0)
  tax             Float         @default(0)
  total           Float
  couponId        String?       @db.Uuid
  stripePaymentId String?       @unique
  idempotencyKey  String?       @unique
  notes           String?
  trackingNumber  String?
  courier         String?
  estimatedDelivery DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  currency        String        @default("MAD")
  deliveryCity    String?
  CmiPayment      CmiPayment?
  Invoice         Invoice?
  address         Address       @relation(fields: [addressId], references: [id])
  coupon          Coupon?       @relation(fields: [couponId], references: [id])
  Customer        Customer?     @relation(fields: [customerId], references: [id])
  Organization    Organization  @relation(fields: [organizationId], references: [id])
  user            User          @relation(fields: [userId], references: [id])
  items           OrderItem[]
  reviews         Review[]
  trackingHistory OrderTracking[]
  webhookEvents   StripeWebhookEvent[]
  notifications   NotificationLog[]     @relation("OrderNotifications")

  @@unique([organizationId, orderNumber])
  @@index([userId])
  @@index([status])
  @@index([organizationId])
  @@index([stripePaymentId])
  @@index([userId, status])
  @@index([organizationId, status])
  @@index([createdAt])
}

model OrderTracking {
  id             String      @id @default(uuid()) @db.Uuid
  orderId        String      @db.Uuid
  status         OrderStatus
  trackingNumber String?
  courier        String?
  notes          String?
  createdAt      DateTime    @default(now())
  order          Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String          @id @default(uuid()) @db.Uuid
  orderId   String          @db.Uuid
  productId String          @db.Uuid
  variantId String?         @db.Uuid
  name      String
  image     String
  price     Float
  quantity  Int
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
}

model Coupon {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  code           String
  description    String?
  type           String
  value          Float
  minOrder       Float?
  maxDiscount    Float?
  usageLimit     Int?
  usedCount      Int          @default(0)
  userLimit      Int          @default(1)
  startDate      DateTime     @default(now())
  endDate        DateTime?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders         Order[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model WishlistItem {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  productId String   @db.Uuid
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  title     String
  body      String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

model RecentlyViewed {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  productId String   @db.Uuid
  viewedAt  DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model AuditLog {
  id             String        @id @default(uuid()) @db.Uuid
  action         String
  userId         String?       @db.Uuid
  organizationId String?       @db.Uuid
  metadata       Json?
  ipAddress      String?
  createdAt      DateTime      @default(now())
  Organization   Organization? @relation(fields: [organizationId], references: [id])
  User           User?         @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([createdAt])
  @@index([organizationId])
}

// ============================================
// PRODUCTION-GRADE AUDIT SYSTEM
// ============================================

model AuditEvent {
  id             String        @id @default(uuid()) @db.Uuid
  sessionId      String       @db.Uuid
  eventType      AuditEventType
  userId         String?      @db.Uuid
  organizationId String       @db.Uuid
  orderId        String?      @db.Uuid
  cartSnapshot   Json?        // Full cart state at event time
  metadata       Json?        // Additional event-specific data
  ipAddress      String?
  userAgent      String?
  fraudScore     Float?       @default(0) // 0-100 risk score
  anomalyFlags   String[]     @default([]) // Detected anomalies
  replayId       String?      @db.Uuid    // Link to replay if created
  createdAt      DateTime     @default(now())
  
  session        AuditSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  replay         AuditReplay? @relation(fields: [replayId], references: [id])
  
  @@index([sessionId])
  @@index([eventType])
  @@index([userId])
  @@index([organizationId])
  @@index([orderId])
  @@index([createdAt])
  @@index([fraudScore])
  @@index([organizationId, createdAt])
}

model AuditSession {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String?      @db.Uuid
  organizationId  String       @db.Uuid
  userAgent       String?
  ipAddress       String?
  referrer        String?
  startTime       DateTime     @default(now())
  endTime         DateTime?
  eventCount      Int          @default(0)
  completedSteps  String[]     @default([]) // Track checkout steps completed
  abandonedAt     DateTime?
  conversionValue Float?       // Final order value if converted
  fraudScore      Float?       @default(0) // Aggregate session risk score
  metadata        Json?
  events          AuditEvent[]
  replays         AuditReplay[]
  
  @@index([userId])
  @@index([organizationId])
  @@index([startTime])
  @@index([endTime])
  @@index([fraudScore])
}

model AuditReplay {
  id              String       @id @default(uuid()) @db.Uuid
  sessionId       String       @db.Uuid
  userId          String?      @db.Uuid
  organizationId  String       @db.Uuid
  name            String
  description     String?
  events          Json         // Ordered list of events for replay
  cartStates      Json         // Cart state at each step
  replayData      Json?        // Additional replay context
  createdAt       DateTime     @default(now())
  replayedAt      DateTime?
  replayedBy      String?      @db.Uuid // User who initiated replay
  
  session         AuditSession @relation(fields: [sessionId], references: [id])
  eventsLinked    AuditEvent[]
  
  @@index([sessionId])
  @@index([userId])
  @@index([organizationId])
  @@index([createdAt])
}

model AuditAlert {
  id              String       @id @default(uuid()) @db.Uuid
  sessionId       String?      @db.Uuid
  userId          String?      @db.Uuid
  organizationId  String       @db.Uuid
  alertType       AuditAlertType
  severity        AlertSeverity
  title           String
  description     String?
  metadata        Json?
  resolved        Boolean      @default(false)
  resolvedAt      DateTime?
  resolvedBy      String?      @db.Uuid
  createdAt       DateTime     @default(now())
  
  @@index([sessionId])
  @@index([userId])
  @@index([organizationId])
  @@index([alertType])
  @@index([severity])
  @@index([resolved])
  @@index([createdAt])
}

enum AuditEventType {
  // Checkout flow events
  CHECKOUT_START
  CHECKOUT_STEP_ADDRESS
  CHECKOUT_STEP_PAYMENT
  CHECKOUT_STEP_REVIEW
  CHECKOUT_COMPLETE
  CHECKOUT_ABANDONED
  
  // Payment events
  PAYMENT_INITIATED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  PAYMENT_RETRY
  
  // Cart events
  CART_VIEWED
  CART_ITEM_ADDED
  CART_ITEM_REMOVED
  CART_ITEM_UPDATED
  CART_CLEARED
  COUPON_APPLIED
  COUPON_REMOVED
  
  // Order events
  ORDER_CREATED
  ORDER_UPDATED
  ORDER_CANCELLED
  ORDER_REFUNDED
  
  // User events
  USER_LOGIN
  USER_LOGOUT
  USER_REGISTER
  ADDRESS_ADDED
  ADDRESS_UPDATED
  
  // Error events
  CHECKOUT_ERROR
  PAYMENT_ERROR
  VALIDATION_ERROR
  SYSTEM_ERROR
}

enum AuditAlertType {
  FRAUD_DETECTED
  ANOMALY_DETECTED
  HIGH_VALUE_ORDER
  RAPID_CHECKOUT
  PAYMENT_FAILURE
  STOCK_ISSUE
  COUPON_ABUSE
  SUSPICIOUS_ACTIVITY
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model CmiPayment {
  id            String           @id @default(uuid()) @db.Uuid
  orderId       String           @unique @db.Uuid
  amount        Float
  currency      String           @default("MAD")
  status        CmiPaymentStatus @default(PENDING)
  cmiOrderId    String
  transactionId String?
  rawResponse   Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  Order         Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Customer {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  email          String
  name           String?
  phone          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Order          Order[]

  @@unique([organizationId, email])
  @@index([organizationId])
}

model Invoice {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  orderId        String       @unique @db.Uuid
  invoiceNumber  String
  ice            String?
  ifNumber       String?
  subtotalHT     Float
  tvaRate        Float        @default(0.20)
  tvaAmount      Float
  totalTTC       Float
  currency       String       @default("MAD")
  buyerName      String
  buyerAddress   String?
  issuedAt       DateTime     @default(now())
  Order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
}

model Membership {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @db.Uuid
  organizationId String       @db.Uuid
  role           OrgRole      @default(MEMBER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  User           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Organization {
  id                 String               @id @default(uuid()) @db.Uuid
  name               String
  slug               String               @unique
  logo               String?
  ownerId            String               @db.Uuid
  stripeCustomerId   String?              @unique
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  defaultLocale      LocaleCode           @default(fr)
  ice                String?
  ifNumber           String?
  legalAddress       String?
  legalName          String?
  AiConversation     AiConversation[]
  AiEvent            AiEvent[]
  AiProductEmbedding AiProductEmbedding[]
  AuditLog           AuditLog[]
  Category           Category[]
  Coupon             Coupon[]
  Customer           Customer[]
  Invoice            Invoice[]
  Membership         Membership[]
  Order              Order[]
  User               User                 @relation(fields: [ownerId], references: [id])
  Product            Product[]
  Subscription       Subscription?

  @@index([ownerId])
  @@index([slug])
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  refreshTokenHash String    @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime  @default(now())
  User             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
}

model StripeWebhookEvent {
  id          String   @id @default(uuid()) @db.Uuid
  eventId     String   @unique
  type        String
  processedAt DateTime @default(now())
  orderId     String?  @db.Uuid
  metadata    Json?
  order       Order?   @relation(fields: [orderId], references: [id])
  
  @@index([eventId])
  @@index([orderId])
}

enum ReservationStatus {
  RESERVED
  CONFIRMED
  RELEASED
  EXPIRED
}

model InventoryReservation {
  id             String            @id @default(uuid()) @db.Uuid
  productId      String            @db.Uuid
  variantId      String?           @db.Uuid
  quantity       Int
  status         ReservationStatus @default(RESERVED)
  expiresAt      DateTime
  idempotencyKey String?
  orderId        String?           @db.Uuid
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  product        Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant        ProductVariant?   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  
  @@index([productId])
  @@index([variantId])
  @@index([status])
  @@index([expiresAt])
  @@index([idempotencyKey])
  @@index([orderId])
}

model NotificationLog {
  id              String              @id @default(uuid()) @db.Uuid
  orderId         String?             @db.Uuid
  userId          String?             @db.Uuid
  type            NotificationType
  channel         NotificationChannel
  recipient       String              // Email or phone number
  subject         String?
  content         String              @db.Text
  status          NotificationStatus  @default(PENDING)
  error           String?             @db.Text
  sentAt          DateTime?
  deliveredAt     DateTime?
  retryCount      Int                 @default(0)
  metadata        Json?               // Additional data (tracking number, etc.)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  order           Order?              @relation("OrderNotifications", fields: [orderId], references: [id], onDelete: Cascade)
  user            User?               @relation("UserNotificationLogs", fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([orderId])
  @@index([userId])
  @@index([type])
  @@index([channel])
  @@index([status])
  @@index([createdAt])
}

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  organizationId       String             @unique @db.Uuid
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 PlanTier           @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  Organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status])
}

model AiConversation {
  id             String               @id @default(uuid()) @db.Uuid
  userId         String?              @db.Uuid
  organizationId String               @db.Uuid
  status         AiConversationStatus @default(OPEN)
  locale         LocaleCode           @default(fr)
  channel        String               @default("web")
  title          String?
  summary        String?
  metadata       Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  Organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  User           User?                @relation(fields: [userId], references: [id])
  AiMessage      AiMessage[]

  @@index([organizationId, createdAt])
  @@index([status])
  @@index([userId, createdAt])
}

model AiEvent {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  userId         String?      @db.Uuid
  productId      String?      @db.Uuid
  type           AiEventType
  query          String?
  score          Float?
  metadata       Json?
  createdAt      DateTime     @default(now())
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Product        Product?     @relation(fields: [productId], references: [id])
  User           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, type, createdAt])
  @@index([productId, createdAt])
  @@index([userId, createdAt])
}

model AiMessage {
  id             String         @id @default(uuid()) @db.Uuid
  conversationId String         @db.Uuid
  role           AiMessageRole
  content        String
  tokens         Int?
  moderated      Boolean        @default(false)
  blocked        Boolean        @default(false)
  metadata       Json?
  createdAt      DateTime       @default(now())
  AiConversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([role])
}

model AiProductEmbedding {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  productId      String       @unique @db.Uuid
  model          String
  contentHash    String
  embedding      Json
  searchableText String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([contentHash])
  @@index([organizationId])
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  CASH_ON_DELIVERY
  CMI
}

enum NotificationType {
  ORDER_UPDATE
  PRICE_DROP
  BACK_IN_STOCK
  PROMO
  SYSTEM
}

enum CmiPaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum LocaleCode {
  fr
  ar
  darija
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum PlanTier {
  FREE
  PRO
  BUSINESS
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
}

enum AiConversationStatus {
  OPEN
  RESOLVED
  ESCALATED
}

enum AiEventType {
