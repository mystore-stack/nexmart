model GoogleMapsLocation {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  name            String
  address         String
  latitude        Float
  longitude       Float
  locationType    LocationType
  deliveryZone    Json?
  warehouse       Boolean  @default(false)
  store           Boolean  @default(false)
