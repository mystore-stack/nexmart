  @@index([date])
}

// Google Integration Models
model GoogleIntegration {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  service         GoogleService
  enabled         Boolean  @default(false)
  config          Json?
  status          IntegrationStatus @default(DISCONNECTED)
  lastSyncAt      DateTime?
  lastSyncStatus  String?
  error           String?
  healthScore     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  Organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  analyticsEvents GoogleAnalyticsEvent[]
  merchantFeeds   GoogleMerchantFeed[]

  @@unique([organizationId, service])
  @@index([organizationId])
  @@index([service])
  @@index([status])
}

model GoogleAnalyticsEvent {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  integrationId   String   @db.Uuid
  eventType       String
  eventData       Json
  userId          String?  @db.Uuid
  sessionId       String?
  timestamp       DateTime @default(now())

  Organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration     GoogleIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([organizationId, timestamp])
  @@index([integrationId, timestamp])
  @@index([eventType])
  @@index([userId])
}

model GoogleMerchantFeed {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  integrationId   String   @db.Uuid
  feedName        String
  feedUrl         String?
  feedId          String?
  status          FeedStatus @default(PENDING)
  totalProducts   Int      @default(0)
  processedProducts Int     @default(0)
  lastGeneratedAt DateTime?
  lastSyncAt      DateTime?
  error           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  Organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration     GoogleIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, feedName])
  @@index([organizationId])
  @@index([integrationId])
  @@index([status])
}

model GoogleOAuthAccount {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  googleId        String
  email           String
  name            String?
  picture         String?
  accessToken     String
  refreshToken    String?
  tokenExpiresAt  DateTime?
  scopes          String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([googleId])
  @@unique([userId])
  @@index([email])
}

model GoogleSearchConsoleSite {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  siteUrl         String
  verified        Boolean  @default(false)
  verificationMethod String?
  sitemapUrl      String?
  lastCrawlAt     DateTime?
  crawlErrors     Int      @default(0)
  indexedPages    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  Organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, siteUrl])
  @@index([organizationId])
  @@index([verified])
}

model GoogleBusinessProfile {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  placeId         String
  name            String
  address         String?
  phone           String?
  website         String?
  categories      String[]
  rating          Float?
  reviewCount     Int?
  verified        Boolean  @default(false)
  lastSyncAt      DateTime?
