generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(uuid()) @db.Uuid
  email                   String                   @unique
  name                    String
  password                String
  avatar                  String?
  phone                   String?
  role                    Role                     @default(USER)
  emailVerified           Boolean                  @default(false)
  verifyToken             String?
  resetToken              String?
  resetExpires            DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  locale                  LocaleCode               @default(fr)
  AIBulkImports           AIBulkImport[]
  AIProductJobs           AIProductJob[]
  addresses               Address[]
  AiConversation          AiConversation[]
  AiEvent                 AiEvent[]
  AiProductGeneration     AiProductGeneration[]
  analyticsEvents         AnalyticsEvent[]
  analyticsSessions       AnalyticsSession[]
  AuditLog                AuditLog[]
  campaignEvents          CampaignEvent[]
  cart                    CartItem[]
  cartReminders           CartReminder[]
  churnPredictions        ChurnPrediction[]
  customerSegment         CustomerSegment[]
  emailLogs               EmailLog[]
  eventTracking           EventTracking[]
  googleOAuthAccount      GoogleOAuthAccount?
  loyaltyPoints           LoyaltyPoints[]
  marketingSegmentMembers MarketingSegmentMember[]
  Membership              Membership[]
  notifications           Notification[]
  notificationLogs        NotificationLog[]        @relation("UserNotificationLogs")
  orders                  Order[]
  Organization            Organization[]           @relation("OrganizationOwner")
  viewedProducts          RecentlyViewed[]
  recommendations         Recommendation[]
  campaignUsers           RetentionCampaignUser[]
  reviews                 Review[]
  reviewRequests          ReviewRequest[]
  Session                 Session[]
  userProfile             UserProfile?
  welcomeSeries           WelcomeSeries?
  wishlist                WishlistItem[]

  @@index([email])
}

model Address {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  name      String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  country   String
  zip       String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([userId])
}

model Category {
  id                           String                       @id @default(uuid()) @db.Uuid
  organizationId               String                       @db.Uuid
  name                         String
  slug                         String
  description                  String?
  image                        String?
  parentId                     String?                      @db.Uuid
  createdAt                    DateTime                     @default(now())
  analyticsEvents              AnalyticsEvent[]
  buildYourOwnBundleCategories BuildYourOwnBundleCategory[]
  Organization                 Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent                       Category?                    @relation("SubCategories", fields: [parentId], references: [id])
  children                     Category[]                   @relation("SubCategories")
  eventTracking                EventTracking[]
  featuredCategories           FeaturedCategory[]
  products                     Product[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Product {
  id                               String                            @id @default(uuid()) @db.Uuid
  organizationId                   String                            @db.Uuid
  name                             String
  slug                             String
  description                      String
  price                            Float
  comparePrice                     Float?
  cost                             Float?
  categoryId                       String                            @db.Uuid
  images                           String[]
  tags                             String[]
  sku                              String
  stock                            Int                               @default(0)
  lowStockAt                       Int                               @default(5)
  weight                           Float?
  published                        Boolean                           @default(false)
  featured                         Boolean                           @default(false)
  rating                           Float                             @default(0)
  reviewCount                      Int                               @default(0)
  soldCount                        Int                               @default(0)
  createdAt                        DateTime                          @default(now())
  updatedAt                        DateTime                          @updatedAt
  aiProductImages                  AIProductImage[]
  aiProductPricing                 AIProductPricing[]
  aiProductSEOs                    AIProductSEO[]
  AiEvent                          AiEvent[]
  AiProductEmbedding               AiProductEmbedding?
  AiProductGeneration              AiProductGeneration[]
  analyticsEvents                  AnalyticsEvent[]
  bundleProducts                   BundleProduct[]
  cartItems                        CartItem[]
  dynamicPrice                     DynamicPrice?
  eventTracking                    EventTracking[]
  flashDealProducts                FlashDealProduct[]
  frequentlyBoughtTogetherProducts FrequentlyBoughtTogetherProduct[]
  reservations                     InventoryReservation[]
  mysteryBoxProducts               MysteryBoxProduct[]
  orderItems                       OrderItem[]
  category                         Category                          @relation(fields: [categoryId], references: [id])
  Organization                     Organization                      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ProductPublishingHistory         ProductPublishingHistory[]
  ProductRevision                  ProductRevision[]
  variants                         ProductVariant[]
  recentlyViewed                   RecentlyViewed[]
  reviews                          Review[]
  sponsoredProducts                SponsoredProduct[]
  stockAlertLogs                   StockAlertLog[]
  superDeals                       SuperDeal[]
  wishlistItems                    WishlistItem[]
  inventoryUpdateLogs              InventoryUpdateLog[]

  @@unique([organizationId, sku])
  @@unique([organizationId, slug])
  @@index([categoryId])
  @@index([published])
  @@index([featured])
  @@index([organizationId])
}

model ProductVariant {
  id           String                 @id @default(uuid()) @db.Uuid
  productId    String                 @db.Uuid
  name         String
  value        String
  label        String
  price        Float?
  stock        Int                    @default(0)
  sku          String?
  cartItems    CartItem[]
  reservations InventoryReservation[]
  orderItems   OrderItem[]
  product      Product                @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Review {
  id               String   @id @default(uuid()) @db.Uuid
  productId        String   @db.Uuid
  userId           String   @db.Uuid
  rating           Int
  title            String?
  body             String
  images           String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  helpfulCount     Int      @default(0)
  orderId          String?  @db.Uuid
  verifiedPurchase Boolean  @default(false)
  order            Order?   @relation(fields: [orderId], references: [id])
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
  @@index([orderId])
}

model CartItem {
  id        String          @id @default(uuid()) @db.Uuid
  userId    String          @db.Uuid
  productId String          @db.Uuid
  variantId String?         @db.Uuid
  quantity  Int             @default(1)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([userId, productId, variantId])
  @@index([userId])
}

model Order {
  id                String               @id @default(uuid()) @db.Uuid
  organizationId    String               @db.Uuid
  orderNumber       String
  userId            String               @db.Uuid
  customerId        String?              @db.Uuid
  addressId         String               @db.Uuid
  status            OrderStatus          @default(PENDING)
  paymentStatus     PaymentStatus        @default(PENDING)
  paymentMethod     PaymentMethod
  subtotal          Float
  discount          Float                @default(0)
  shipping          Float                @default(0)
  tax               Float                @default(0)
  total             Float
  couponId          String?              @db.Uuid
  stripePaymentId   String?              @unique
  notes             String?
  trackingNumber    String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  currency          String               @default("MAD")
  deliveryCity      String?
  courier           String?
  estimatedDelivery DateTime?
  idempotencyKey    String?              @unique
  analyticsEvents   AnalyticsEvent[]
  CmiPayment        CmiPayment?
  emailLogs         EmailLog[]
  eventTracking     EventTracking[]
  Invoice           Invoice?
  notifications     NotificationLog[]    @relation("OrderNotifications")
  address           Address              @relation(fields: [addressId], references: [id])
  coupon            Coupon?              @relation(fields: [couponId], references: [id])
  Customer          Customer?            @relation(fields: [customerId], references: [id])
  Organization      Organization         @relation(fields: [organizationId], references: [id])
  user              User                 @relation(fields: [userId], references: [id])
  items             OrderItem[]
  trackingHistory   OrderTracking[]
  reviews           Review[]
  webhookEvents     StripeWebhookEvent[]

  @@unique([organizationId, orderNumber])
  @@index([userId])
  @@index([status])
  @@index([organizationId])
  @@index([stripePaymentId])
  @@index([userId, status])
  @@index([organizationId, status])
  @@index([createdAt])
}

model OrderTracking {
  id             String      @id @default(uuid()) @db.Uuid
  orderId        String      @db.Uuid
  status         OrderStatus
  trackingNumber String?
  courier        String?
  notes          String?
  createdAt      DateTime    @default(now())
  order          Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String          @id @default(uuid()) @db.Uuid
  orderId   String          @db.Uuid
  productId String          @db.Uuid
  variantId String?         @db.Uuid
  name      String
  image     String
  price     Float
  quantity  Int
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
}

model Coupon {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  code           String
  description    String?
  type           String
  value          Float
  minOrder       Float?
  maxDiscount    Float?
  usageLimit     Int?
  usedCount      Int          @default(0)
  userLimit      Int          @default(1)
  startDate      DateTime     @default(now())
  endDate        DateTime?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders         Order[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model WishlistItem {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  productId String   @db.Uuid
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model HeroBanner {
  id                     String                @id @default(uuid()) @db.Uuid
  title                  String
  description            String?
  mobileImageUrl         String?
  isActive               Boolean               @default(true)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  backgroundOverlayColor String?
  badgeText              String?
  desktopImageUrl        String?
  highlightedText        String?
  primaryButtonLink      String?
  primaryButtonText      String?
  secondaryButtonLink    String?
  secondaryButtonText    String?
  backgroundColor        String?
  displayOrder           Int                   @default(0)
  expireDate             DateTime?
  heroHeight             String                @default("90vh")
  heroPosition           String                @default("center")
  overlayOpacity         Float                 @default(0.5)
  primaryButtonColor     String?
  publishDate            DateTime?
  secondaryButtonColor   String?
  seoDescription         String?
  seoTitle               String?
  subtitle               String?
  textColor              String?
  videoUrl               String?
  impressions            Int                   @default(0)
  primaryButtonClicks    Int                   @default(0)
  secondaryButtonClicks  Int                   @default(0)
  abTestGroupId          String?               @db.Uuid
  animationSettings      Json?
  conversionCount        Int                   @default(0)
  createdBy              String?               @db.Uuid
  ctaButtons             Json                  @default("[]")
  organizationId         String?               @db.Uuid
  priorityScore          Int                   @default(0)
  publishedAt            DateTime?
  revenueGenerated       Float                 @default(0)
  status                 CMSContentStatus      @default(PUBLISHED)
  templateId             String?               @db.Uuid
  eventTracking          EventTracking[]
  abTestGroup            HeroBannerABTest?     @relation(fields: [abTestGroupId], references: [id])
  template               HeroBannerTemplate?   @relation(fields: [templateId], references: [id])
  analytics              HeroBannerAnalytics[]

  @@index([isActive])
  @@index([displayOrder])
  @@index([publishDate])
  @@index([expireDate])
  @@index([createdAt])
  @@index([organizationId])
  @@index([status])
  @@index([priorityScore])
}

model HeroBannerAnalytics {
  id          String     @id @default(uuid()) @db.Uuid
  bannerId    String     @db.Uuid
  eventType   String
  deviceType  String?
  country     String?
  referrer    String?
  landingPage String?
  sessionId   String?
  userAgent   String?
  ipAddress   String?
  createdAt   DateTime   @default(now())
  banner      HeroBanner @relation(fields: [bannerId], references: [id], onDelete: Cascade)

  @@index([bannerId])
  @@index([eventType])
  @@index([createdAt])
  @@index([sessionId])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  title     String
  body      String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

model RecentlyViewed {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  productId String   @db.Uuid
  viewedAt  DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model AuditLog {
  id             String        @id @default(uuid()) @db.Uuid
  action         String
  userId         String?       @db.Uuid
  organizationId String?       @db.Uuid
  metadata       Json?
  ipAddress      String?
  createdAt      DateTime      @default(now())
  Organization   Organization? @relation(fields: [organizationId], references: [id])
  User           User?         @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([createdAt])
  @@index([organizationId])
}

model EventTracking {
  id          String      @id @default(uuid()) @db.Uuid
  eventType   String
  sessionId   String?
  userId      String?     @db.Uuid
  productId   String?     @db.Uuid
  categoryId  String?     @db.Uuid
  bannerId    String?     @db.Uuid
  orderId     String?     @db.Uuid
  deviceType  String?
  browser     String?
  country     String?
  referrer    String?
  landingPage String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime    @default(now())
  banner      HeroBanner? @relation(fields: [bannerId], references: [id])
  category    Category?   @relation(fields: [categoryId], references: [id])
  order       Order?      @relation(fields: [orderId], references: [id])
  product     Product?    @relation(fields: [productId], references: [id])
  user        User?       @relation(fields: [userId], references: [id])

  @@index([eventType])
  @@index([sessionId])
  @@index([userId])
  @@index([productId])
  @@index([createdAt])
  @@index([utmCampaign])
}

model ABTest {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  variantA       Json
  variantB       Json
  trafficSplit   Int             @default(50)
  status         String          @default("draft")
  startDate      DateTime?
  endDate        DateTime?
  winningVariant String?
  confidence     Float?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  variants       ABTestVariant[]

  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model ABTestVariant {
  id          String   @id @default(uuid()) @db.Uuid
  testId      String   @db.Uuid
  variant     String
  impressions Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  revenue     Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  test        ABTest   @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId])
  @@index([variant])
}

model AdCampaign {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  platform    String
  campaignId  String?
  status      String    @default("active")
  budget      Float?
  spent       Float     @default(0)
  impressions Int       @default(0)
  clicks      Int       @default(0)
  conversions Int       @default(0)
  revenue     Float     @default(0)
  startDate   DateTime
  endDate     DateTime?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([platform])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([utmCampaign])
}

model AuditEvent {
  id             String         @id @default(uuid()) @db.Uuid
  sessionId      String?        @db.Uuid
  eventType      AuditEventType
  userId         String?        @db.Uuid
  organizationId String         @db.Uuid
  orderId        String?        @db.Uuid
  cartSnapshot   Json?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  fraudScore     Float?         @default(0)
  anomalyFlags   String[]       @default([])
  replayId       String?        @db.Uuid
  createdAt      DateTime       @default(now())
  replay         AuditReplay?   @relation(fields: [replayId], references: [id])
  session        AuditSession?  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([eventType])
  @@index([userId])
  @@index([organizationId])
  @@index([orderId])
  @@index([createdAt])
  @@index([fraudScore])
  @@index([organizationId, createdAt])
}

model AuditSession {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String?       @db.Uuid
  organizationId  String        @db.Uuid
  userAgent       String?
  ipAddress       String?
  referrer        String?
  startTime       DateTime      @default(now())
  endTime         DateTime?
  eventCount      Int           @default(0)
  completedSteps  String[]      @default([])
  abandonedAt     DateTime?
  conversionValue Float?
  fraudScore      Float?        @default(0)
  metadata        Json?
  alerts          AuditAlert[]
  events          AuditEvent[]
  replays         AuditReplay[]

  @@index([userId])
  @@index([organizationId])
  @@index([startTime])
  @@index([endTime])
  @@index([fraudScore])
}

model AuditReplay {
  id             String       @id @default(uuid()) @db.Uuid
  sessionId      String       @db.Uuid
  userId         String?      @db.Uuid
  organizationId String       @db.Uuid
  name           String
  description    String?
  events         Json
  cartStates     Json
  replayData     Json?
  createdAt      DateTime     @default(now())
  replayedAt     DateTime?
  replayedBy     String?      @db.Uuid
  eventsLinked   AuditEvent[]
  session        AuditSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([userId])
  @@index([organizationId])
  @@index([createdAt])
}

model AuditAlert {
  id             String         @id @default(uuid()) @db.Uuid
  sessionId      String?        @db.Uuid
  userId         String?        @db.Uuid
  organizationId String         @db.Uuid
  alertType      AuditAlertType
  severity       AlertSeverity
  title          String
  description    String?
  metadata       Json?
  resolved       Boolean        @default(false)
  resolvedAt     DateTime?
  resolvedBy     String?        @db.Uuid
  createdAt      DateTime       @default(now())
  session        AuditSession?  @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([userId])
  @@index([organizationId])
  @@index([alertType])
  @@index([severity])
  @@index([resolved])
  @@index([createdAt])
}

model CmiPayment {
  id            String           @id @default(uuid()) @db.Uuid
  orderId       String           @unique @db.Uuid
  amount        Float
  currency      String           @default("MAD")
  status        CmiPaymentStatus @default(PENDING)
  cmiOrderId    String
  transactionId String?
  rawResponse   Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  Order         Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Customer {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  email          String
  name           String?
  phone          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Order          Order[]

  @@unique([organizationId, email])
  @@index([organizationId])
}

model Invoice {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  orderId        String       @unique @db.Uuid
  invoiceNumber  String
  ice            String?
  ifNumber       String?
  subtotalHT     Float
  tvaRate        Float        @default(0.20)
  tvaAmount      Float
  totalTTC       Float
  currency       String       @default("MAD")
  buyerName      String
  buyerAddress   String?
  issuedAt       DateTime     @default(now())
  Order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
}

model Membership {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @db.Uuid
  organizationId String       @db.Uuid
  role           OrgRole      @default(MEMBER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  Organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  User           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Organization {
  id                        String                     @id @default(uuid()) @db.Uuid
  name                      String
  slug                      String                     @unique
  logo                      String?
  ownerId                   String                     @db.Uuid
  stripeCustomerId          String?                    @unique
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  defaultLocale             LocaleCode                 @default(fr)
  ice                       String?
  ifNumber                  String?
  legalAddress              String?
  legalName                 String?
  customDomain              String?                    @unique
  paymentMethods            PaymentMethod[]
  planId                    String?                    @db.Uuid
  primaryColor              String?
  status                    OrganizationStatus         @default(ACTIVE)
  subscriptionId            String?                    @unique @db.Uuid
  trialEndsAt               DateTime?
  aiBulkImports             AIBulkImport[]
  aiModelConfig             AIModelConfig?
  aiProductAnalytics        AIProductAnalytics[]
  aiProductCategories       AIProductCategory[]
  aiProductImages           AIProductImage[]
  aiProductJobs             AIProductJob[]
  aiProductPricing          AIProductPricing[]
  aiProductSEOs             AIProductSEO[]
  advertisements            Advertisement[]
  AiConversation            AiConversation[]
  AiEvent                   AiEvent[]
  AiProductEmbedding        AiProductEmbedding[]
  AiProductGeneration       AiProductGeneration[]
  AnalyticsMetric           AnalyticsMetric[]
  AuditLog                  AuditLog[]
  BICustomerSegment         BICustomerSegment[]
  buildYourOwnBundles       BuildYourOwnBundle[]
  buyMoreSaveMores          BuyMoreSaveMore[]
  Category                  Category[]
  ChurnPrediction           ChurnPrediction[]
  CohortAnalysis            CohortAnalysis[]
  Coupon                    Coupon[]
  Customer                  Customer[]
  dailySalesReports         DailySalesReport[]
  DynamicPrice              DynamicPrice[]
  emailCampaigns            EmailCampaign[]
  Experiment                Experiment[]
  flashDeals                FlashDeal[]
  frequentlyBoughtTogethers FrequentlyBoughtTogether[]
  globalComponents          GlobalComponent[]
  googleAnalyticsEvents     GoogleAnalyticsEvent[]
  googleBusinessProfiles    GoogleBusinessProfile[]
  googleIntegrations        GoogleIntegration[]
  googleMapsLocations       GoogleMapsLocation[]
  googleMerchantFeeds       GoogleMerchantFeed[]
  googleSearchConsoleSites  GoogleSearchConsoleSite[]
  Invoice                   Invoice[]
  MarketingCampaign         MarketingCampaign[]
  marketingSegments         MarketingSegment[]
