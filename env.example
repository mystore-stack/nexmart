# ═══════════════════════════════════════════════════
# NexMart MA — Enterprise Environment Variables
# Copy to .env.local and fill all required fields
# ═══════════════════════════════════════════════════

# App
NEXT_PUBLIC_APP_URL=https://nexmart.ma
NODE_ENV=development
DEFAULT_ORGANIZATION_SLUG=nexmart

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/nexmart?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host/nexmart?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379

# Auth — Legacy JWT (existing sessions)
JWT_SECRET=your-32-plus-chars-secret-key-here
JWT_REFRESH_SECRET=your-32-plus-chars-refresh-secret-key-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# NextAuth v5 — Unified sessions + Google OAuth
# Generate: openssl rand -hex 32
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (console.cloud.google.com)
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI — Claude (console.anthropic.com)
# Powers: AI search, chatbot, descriptions, recommendations
ANTHROPIC_API_KEY=sk-ant-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="NexMart Maroc <noreply@nexmart.ma>"

# CMI Payment Gateway (Morocco)
CMI_MERCHANT_ID=your-merchant-id
CMI_STORE_KEY=your-store-key
CMI_CALLBACK_URL=https://nexmart.ma/api/payments/cmi-callback

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_SEARCH=true
NEXT_PUBLIC_ENABLE_AI_CHAT=true
NEXT_PUBLIC_ENABLE_GOOGLE_LOGIN=true

# n8n Automation Webhooks
N8N_WEBHOOK_SECRET=your-n8n-secret-32-chars
N8N_ORDER_WEBHOOK=https://your-n8n.railway.app/webhook/nexmart-orders
N8N_USER_WEBHOOK=https://your-n8n.railway.app/webhook/nexmart-users
N8N_PAYMENT_WEBHOOK=https://your-n8n.railway.app/webhook/nexmart-payments

# ════════════════════════════════════
# Telegram Notifications
# ════════════════════════════════════
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-chat-id-or-channel-id

# Cron Secret (random string for securing cron endpoints)
CRON_SECRET=your-random-cron-secret-32-chars
