    "@radix-ui/react-tooltip": "^1.1.0",
    "@stripe/react-stripe-js": "^2.7.0",
    "@stripe/stripe-js": "^4.1.0",
    "@tanstack/react-query": "^5.50.0",
    "@tanstack/react-table": "^8.18.0",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "autoprefixer": "^10.4.19",
    "axios": "^1.7.2",
